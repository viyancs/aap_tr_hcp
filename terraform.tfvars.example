# This file is for local testing only.
# For HCP Terraform / Terraform Cloud, configure these values in the Workspace Variables UI instead.

location          = "eastus"
prefix            = "demo"
vm_admin_username = "azureuser"
vm_size           = "Standard_B2s"
ssh_public_key    = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQD..."
my_ip_cidr        = "203.0.113.10/32"

aap_host                  = "https://controller.example.com"
aap_username              = "svc_terraform"
aap_password              = "replace-me"
aap_insecure_skip_verify  = false
aap_organization_name     = "Default"
aap_job_template_name     = "linux-install-nginx"
